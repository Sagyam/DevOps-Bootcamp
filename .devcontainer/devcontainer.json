{
  "name": "Linux Fundamentals Bootcamp",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "student",

  // Prime the offline tldr cache and set up delta for nicer git diffs.
  "postCreateCommand": "tldr --update || true; git config --global core.pager 'delta'; git config --global delta.navigate true; git config --global delta.line-numbers true",

  // Add support for Docker in Docker
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:3.1.0": {
      "version": "latest",
      "containerUser": "student"
    }
  },

  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": { "path": "/usr/bin/zsh" }
        },
        // Icons are disabled in Neovim (vim.g.have_nerd_font = false), so no Nerd
        // Font is required. This just picks a clean monospace per platform.
        "terminal.integrated.fontFamily": "Menlo, Consolas, 'DejaVu Sans Mono', monospace"
      },

      // Minimal on purpose — this is a terminal-first class.
      "extensions": [
        "redhat.vscode-yaml",
        "sdras.night-owl",
        "tomoki1207.pdf",
        "ms-vscode-remote.remote-containers",
        "docker.docker",
        "ms-azuretools.vscode-containers",
        "mikestead.dotenv",
        "hashicorp.terraform",
        "thang-nm.catppuccin-perfect-icons"
      ]
    }
  }
}